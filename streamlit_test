import streamlit as st
import pandas as pd
import matplotlib.pyplot as plt

st.set_page_config(page_title="Dashboard", layout="wide")

st.title("📊 Streamlit Dashboard")

# --- サンプルデータ（あなたのCSVに置き換え可） ---
@st.cache_data
def load_data():
    # 例: CSVを読むならこう
    # return pd.read_csv("data.csv")
    df = pd.DataFrame({
        "氏名": ["田中太郎", "佐藤花子", "鈴木一郎", "山田次郎"],
        "年代": ["20代", "30代", "20代", "40代"],
        "学習時間": [12.5, 8.0, 15.2, 5.5],
        "スコア": [620, 710, 580, 660],
    })
    return df

df = load_data()

# --- サイドバー：フィルタ ---
st.sidebar.header("フィルタ")
age_options = sorted(df["年代"].dropna().unique().tolist())
selected_ages = st.sidebar.multiselect("年代", age_options, default=age_options)

df_f = df[df["年代"].isin(selected_ages)].copy()

# --- KPI ---
c1, c2, c3 = st.columns(3)
c1.metric("人数", f"{len(df_f):,}")
c2.metric("平均学習時間", f"{df_f['学習時間'].mean():.1f} h")
c3.metric("平均スコア", f"{df_f['スコア'].mean():.0f}")

st.divider()

# --- レイアウト：左に表、右にグラフ ---
left, right = st.columns([1.2, 1])

with left:
    st.subheader("データ")
    st.dataframe(df_f, use_container_width=True)

with right:
    st.subheader("散布図：学習時間 × スコア")
    fig, ax = plt.subplots()
    ax.scatter(df_f["学習時間"], df_f["スコア"])
    ax.set_xlabel("学習時間 (h)")
    ax.set_ylabel("スコア")
    st.pyplot(fig, clear_figure=True)
